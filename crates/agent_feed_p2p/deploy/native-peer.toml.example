[p2p]
enabled = true
network_id = "agent-feed-mainnet"
profile = "mainnet"

[p2p.mainnet]
enabled = true
edge_base_url = "https://edge.feed.aberration.technology"
bootstrap_peers = [
  "/dns4/edge.feed.aberration.technology/tcp/7747",
  "/dns4/edge.feed.aberration.technology/udp/7747/quic-v1",
  "/dns4/edge.feed.aberration.technology/udp/443/webrtc-direct",
]

[p2p.publish]
enabled = false
feed_name = "workstation"
story_only = true
settled_only = true
raw_events = false
min_score = 75
summarizer = "codex-exec"
summary_style = "austere technical broadcast; terse contextual headline; strong verb/object/outcome"
summary_prompt_max_chars = 3000

[p2p.publish.github]
required_org = ""
required_teams = []

[p2p.fabric]
enabled = true
subscribe = false
browser_handoff = true

[p2p.subscribe]
enabled = true
auto_follow_public = false

[p2p.subscribe.github]
follow_orgs = []
follow_teams = []
