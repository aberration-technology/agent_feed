[Unit]
Description=feed p2p edge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agent-feed
Group=agent-feed
EnvironmentFile=/etc/agent-feed/edge.env
ExecStart=/usr/local/bin/agent-feed edge serve --config /etc/agent-feed/edge.toml --bind 127.0.0.1:${edge_loopback_port} --edge-base-url ${edge_base_url} --browser-app-base-url ${browser_app_base_url} --github-callback-url ${github_callback_url} --network-id ${network_id} --bootstrap-host ${bootstrap_domain_name}
Restart=on-failure
RestartSec=3
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/agent-feed /etc/agent-feed

[Install]
WantedBy=multi-user.target
