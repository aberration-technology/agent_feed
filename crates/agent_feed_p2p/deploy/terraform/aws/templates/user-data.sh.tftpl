#!/usr/bin/env bash
set -euxo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y --no-install-recommends \
  build-essential \
  ca-certificates \
  caddy \
  curl \
  git \
  jq \
  libssl-dev \
  pkg-config \
  unzip

if ! command -v aws >/dev/null 2>&1; then
  tmpdir="$(mktemp -d)"
  curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "$tmpdir/awscliv2.zip"
  unzip -q "$tmpdir/awscliv2.zip" -d "$tmpdir"
  "$tmpdir/aws/install" --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli --update
  rm -rf "$tmpdir"
fi

if ! id agent-feed >/dev/null 2>&1; then
  useradd --system --home-dir /var/lib/agent-feed --create-home --shell /usr/sbin/nologin agent-feed
fi

install -d -m 0755 /etc/agent-feed
install -d -m 0750 -o agent-feed -g agent-feed /var/lib/agent-feed
install -d -m 0755 /usr/local/bin

cat >/etc/agent-feed/edge.env <<'EOF_EDGE_ENV'
${edge_env}
EOF_EDGE_ENV
github_client_id="$(aws ssm get-parameter --name "${github_client_id_parameter}" --with-decryption --query Parameter.Value --output text 2>/dev/null || true)"
github_client_secret="$(aws ssm get-parameter --name "${github_client_secret_param}" --with-decryption --query Parameter.Value --output text 2>/dev/null || true)"
if [ -n "$github_client_id" ]; then
  printf 'AGENT_FEED_GITHUB_CLIENT_ID=%s\n' "$github_client_id" >>/etc/agent-feed/edge.env
fi
if [ -n "$github_client_secret" ]; then
  printf 'AGENT_FEED_GITHUB_CLIENT_SECRET=%s\n' "$github_client_secret" >>/etc/agent-feed/edge.env
fi
chmod 0640 /etc/agent-feed/edge.env
chown root:agent-feed /etc/agent-feed/edge.env

cat >/etc/agent-feed/edge.toml <<'EOF_EDGE_TOML'
${edge_toml}
EOF_EDGE_TOML
chmod 0644 /etc/agent-feed/edge.toml

cat >/etc/caddy/Caddyfile <<'EOF_CADDY'
${caddyfile}
EOF_CADDY

cat >/etc/systemd/system/agent-feed-edge.service <<'EOF_SERVICE'
${edge_service_unit}
EOF_SERVICE

if [ "${agent_feed_install_source}" = "s3" ]; then
  aws s3 cp "${agent_feed_binary_s3_uri}" /usr/local/bin/agent-feed
  chmod 0755 /usr/local/bin/agent-feed
elif [ "${agent_feed_install_source}" = "crate" ]; then
  if [ ! -x /root/.cargo/bin/cargo ]; then
    curl https://sh.rustup.rs -sSf | sh -s -- -y --profile minimal
  fi
  export HOME=/root
  export CARGO_HOME=/root/.cargo
  export RUSTUP_HOME=/root/.rustup
  # shellcheck disable=SC1091
  source /root/.cargo/env
  cargo install --locked agent_feed_cli --version "${agent_feed_crate_version}" --bin agent-feed
else
  if [ ! -x /root/.cargo/bin/cargo ]; then
    curl https://sh.rustup.rs -sSf | sh -s -- -y --profile minimal
  fi
  export HOME=/root
  export CARGO_HOME=/root/.cargo
  export RUSTUP_HOME=/root/.rustup
  # shellcheck disable=SC1091
  source /root/.cargo/env
  cargo install \
    --locked \
    --git "${agent_feed_git_repository}" \
    --branch "${agent_feed_git_ref}" \
    --bin agent-feed \
    agent_feed_cli
fi
if [ "${agent_feed_install_source}" != "s3" ]; then
  ln -sf /root/.cargo/bin/agent-feed /usr/local/bin/agent-feed
fi

systemctl daemon-reload
systemctl enable caddy
systemctl restart caddy
systemctl enable agent-feed-edge
systemctl restart agent-feed-edge
