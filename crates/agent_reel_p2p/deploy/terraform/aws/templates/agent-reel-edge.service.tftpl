[Unit]
Description=feed p2p edge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agent-reel
Group=agent-reel
EnvironmentFile=/etc/agent-reel/edge.env
ExecStart=/usr/local/bin/agent-reel edge serve --config /etc/agent-reel/edge.toml --bind 127.0.0.1:${edge_loopback_port}
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/agent-reel /etc/agent-reel

[Install]
WantedBy=multi-user.target
